# InterCraft — environment template
# Copy to .env.local (gitignored) and fill in real values for local dev.

# ---- Database (Phase 1: requires user-provided online DB; placeholder) ----
DATABASE_URL=postgresql+asyncpg://PLACEHOLDER:PLACEHOLDER@localhost:5432/intercraft
# When using Neon/Supabase, append ?sslmode=require
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xyz.us-east-1.aws.neon.tech/intercraft?sslmode=require

# ---- Redis (local default works) ----
REDIS_URL=redis://localhost:6379/0

# ---- Security — DEV-ONLY dummy. PRODUCTION MUST REPLACE. ----
# Generate via: openssl rand -hex 32
JWT_SECRET=dev-only-dummy-32bytes-xxxxxxxxxxxxxxxxxxxxxx
# Generate via: openssl rand -base64 32
MASTER_KEY=rMOLKPmLQDBnqQBa69D5SjbuEVxUNnDitsazhxwYV1Q=

# ---- App ----
BCRYPT_COST_ROUNDS=12
ACCESS_TTL=900
REFRESH_TTL=604800
MAX_ACTIVE_SESSIONS=5
CORS_ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO
APP_ENV=development

# ---- AI / LLM (Phase 4) — DeepSeek V4 Pro via OpenAI-compatible API ----
# API key from https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...
# DeepSeek OpenAI-compatible endpoint
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Model name (deepseek-v4-pro = V4 Pro, deepseek-v4-flash = fast)
DEEPSEEK_MODEL=deepseek-v4-pro
# Per-node model overrides (flash = fast/cheap for live interview, pro = quality for scoring/report)
DEEPSEEK_MODEL_INTAKE=deepseek-v4-flash
DEEPSEEK_MODEL_QUESTION_GEN=deepseek-v4-flash
DEEPSEEK_MODEL_SCORE=deepseek-v4-pro
DEEPSEEK_MODEL_REPORT=deepseek-v4-pro
# Enable chain-of-thought thinking mode (true/false)
DEEPSEEK_THINKING_ENABLED=true
# Reasoning effort: high / max (low/medium map to high for compatibility)
DEEPSEEK_REASONING_EFFORT=high
# Monthly token quota per user (500K ≈ 18 interviews)
MONTHLY_TOKEN_QUOTA=500000

# ---- Export (Phase 6) ----
EXPORT_STORAGE_PATH=/tmp/exports/

# ---- REQ-041 US1 FR-007 — Agent error-handling refactor (dual-track 1-week window) ----
# Toggles the 041 ``@node_error_handler`` decorator + ``state.error`` envelope.
# Independent of 040 ``INTERVIEW_USE_V2_*`` flags (interview-only namespace).
# When false (default): legacy behaviour — exceptions propagate as-is, no state.error.
# When true: every LLM node writes NodeError to state["error"], API exposes
#            ``error_category`` + ``node_name`` + ``cause`` + ``error_legacy_str``.
# TODO(release-manager): drop this flag after the 1-week observation window.
AGENT_USE_V2_ERROR_HANDLER=false

# ---- REQ-041 US2 FR-007 — Tool binding + control-flow tools (dual-track 1-week window) ----
# Toggles the 041 ``@tool`` decorator + ``bind_tools`` + control-flow tools
# (``think_tool`` / ``MarkComplete``). Both flags default to ``false`` so legacy
# nodes keep their hardcoded tool calls. Flip either flag independently to opt
# in to the new contract:
#
# AGENT_USE_V2_TOOL_BINDING
#   When false (default): nodes call query_*/tavily_search directly (legacy).
#   When true: nodes opt in to ``llm.bind_tools([tavily_search, ...])`` —
#              the LLM owns tool selection (spec US-2 AS1).
#
# AGENT_USE_V2_CONTROL_TOOLS
#   When false (default): ``think_tool`` / ``MarkComplete`` are NOT exposed;
#              the legacy ``correct_count >= 3`` guard continues to drive
#              completion in error_coach.
#   When true: ``think_tool`` + ``MarkComplete`` are bound alongside the
#              query tools so the LLM can reflect (US-2 AS2) and
#              self-terminate via ``MarkComplete`` (US-2 AS3). MarkComplete
#              has priority over the ``correct_count`` loop guard via
#              ``state["_mark_complete"]`` (AC-5.5a front-branch).
#
# Both flags are independent of each other AND of the US1 ``AGENT_USE_V2_ERROR_HANDLER``
# flag (3 flags total, all on separate lines — per AC-7.1).
# TODO(release-manager): drop these flags after the 1-week observation window.
AGENT_USE_V2_TOOL_BINDING=false
AGENT_USE_V2_CONTROL_TOOLS=false

# ---- REQ-041 US2 FR-004 — Tavily API key (optional) ----
# Used by ``tavily_search`` @tool to call https://api.tavily.com/search.
# When empty / unset the tool raises ``TavilyAPIKeyMissingError`` (per AC-4.1a).
# Get a key at https://tavily.com — free tier covers ~1k searches/month.
TAVILY_API_KEY=tvly-...
